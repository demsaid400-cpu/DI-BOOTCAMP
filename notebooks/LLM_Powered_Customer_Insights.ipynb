        "%%shell\n",
        "cat > /tmp/gen_nb.py << 'PYEOF'\n",
        "import json\n",
        "import os\n",
        "import random\n",
        "import numpy as np\n",
        "from pathlib import Path\n",
        "\n",
        "cells = []\n",
        "\n",
        "def code(source):\n",
        "    return {\"cell_type\":\"code\",\"execution_count\":None,\"metadata\":{},\"outputs\":[],\"source\":source}\n",
        "\n",
        "def md(source):\n",
        "    return {\"cell_type\":\"markdown\",\"metadata\":{},\"source\":source}\n",
        "\n",
        "# --- Cells Definition ---\n",
        "cells.append(md(\"\"\"# 🤖 LLM API Integration — Text Intelligence Pipeline\n",
        "## Portfolio Project | Data Analytics Bootcamp 2026\"\"\"))\n",
        "\n",
        "cells.append(code(\"\"\"import pandas as pd\n",
        "import numpy as np\n",
        "import yaml\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "# Config load simulation\n",
        "CONFIG = {'visualization': {'bg_color': '#0D1117', 'dpi': 150, 'accent_colors': {'blue': '#58A6FF', 'red': '#FF7B72', 'green': '#3FB950', 'orange': '#E3B341', 'purple': '#BC8CFF'}}, 'api[...]}\"\"\"))\n",
        "\n",
        "cells.append(code(\"\"\"random.seed(42); np.random.seed(42)\n",
        "REVIEWS = {\"Positive\": [\"Super product!\"], \"Neutral\": [\"Okay.\"], \"Negative\": [\"Bad.\"]}\n",
        "rows = []\n",
        "for sentiment, texts in REVIEWS.items():\n",
        "    for text in texts:\n",
        "        rows.append({'text': text, 'true_sentiment': sentiment, 'category': 'Electronics'})\n",
        "df = pd.DataFrame(rows)\n",
        "print(f'✅ Dataset created: {len(df)} reviews')\n",
        "df.head()\"\"\"))\n",
        "\n",
        "# --- Notebook Assembly ---\n",
        "nb = {\n",
        "    \"nbformat\": 4, \"nbformat_minor\": 5,\n",
        "    \"metadata\": {\"kernelspec\": {\"display_name\":\"Python 3\",\"name\":\"python3\"}},\n",
        "    \"cells\": cells\n",
        "}\n",
        "\n",
        "output_dir = './notebooks/'\n",
        "os.makedirs(output_dir, exist_ok=True)\n",
        "path = os.path.join(output_dir, 'llm_api_integration.ipynb')\n",
        "\n",
        "with open(path,'w',encoding='utf-8') as f:\n",
        "    json.dump(nb, f, ensure_ascii=False, indent=1)\n",
        "\n",
        "print(f\"✅ Notebook generated: {path}\")\n",
        "PYEOF\n",
        "\n",
        "python3 /tmp/gen_nb.py"
