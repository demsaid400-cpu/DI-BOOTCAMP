      "source": [
        "%%writefile config.yaml\n",
        "project:\n",
        "  name: \"LLM API Integration - Text Intelligence Pipeline\"\n",
        "  version: \"1.0.0\"\n",
        "  author: \"SAID\"\n",
        "  description: \"Portfolio project demonstrating real API integration with Claude LLM for text classification, data enrichment and feature generation\"\n",
        "\n",
        "api:\n",
        "  provider: \"anthropic\"\n",
        "  model: \"claude-sonnet-4-6\"\n",
        "  max_tokens: 512\n",
        "  temperature: 0.1\n",
        "  batch_size: 5\n",
        "  rate_limit_delay: 0.5  # seconds between calls\n",
        "\n",
        "dataset:\n",
        "  name: \"E-commerce Customer Reviews\"\n",
        "  n_samples: 50\n",
        "  categories: [\"Electronics\", \"Clothing\", \"Food\", \"Books\", \"Sports\"]\n",
        "  languages: [\"fr\", \"en\"]\n",
        "\n",
        "tasks:\n",
        "  - name: \"sentiment_classification\"\n",
        "    description: \"Classify sentiment as Positive / Neutral / Negative\"\n",
        "  - name: \"topic_extraction\"\n",
        "    description: \"Extract main topics from text\"\n",
        "  - name: \"feature_generation\"\n",
        "    description: \"Generate structured features for downstream ML\"\n",
        "  - name: \"data_enrichment\"\n",
        "    description: \"Enrich raw text with metadata\"\n",
        "\n",
        "visualization:\n",
        "  theme: \"dark\"\n",
        "  bg_color: \"#0D1117\"\n",
        "  accent_colors:\n",
        "    blue: \"#58A6FF\"\n",
        "    red: \"#FF7B72\"\n",
        "    green: \"#3FB950\"\n",
        "    orange: \"#E3B341\"\n",
        "    purple: \"#BC8CFF\"\n",
        "  figsize: [14, 8]\n",
        "  dpi: 150\n",
        "\n",
        "output:\n",
        "  notebook: \"outputs/llm_api_integration.ipynb\"\n",
        "  results_json: \"outputs/api_results.json\"\n",
        "  features_csv: \"outputs/llm_features.csv\"\n",
        "  plots_dir: \"outputs/plots\""
      ],
