        "%%shell\n",
        "cat > ./notebooks/generate_notebook.py << 'PYEOF'\n",
        "import json\n",
        "\n",
        "cells = []\n",
        "\n",
        "def code(source, tags=None):\n",
        "    return {\n",
        "        \"cell_type\": \"code\",\n",
        "        \"execution_count\": None,\n",
        "        \"metadata\": {\"tags\": tags or []},\n",
        "        \"outputs\": [],\n",
        "        \"source\": source if isinstance(source, list) else [source]\n",
        "    }\n",
        "\n",
        "def md(source):\n",
        "    return {\n",
        "        \"cell_type\": \"markdown\",\n",
        "        \"metadata\": {},\n",
        "        \"source\": source if isinstance(source, list) else [source]\n",
        "    }\n",
        "\n",
        "# ─────────────────────────────────────────────\n",
        "# CELL 1 - TITRE\n",
        "# ─────────────────────────────────────────────\n",
        "cells.append(md(\"\"\"# 🤖 LLM API Integration — Text Intelligence Pipeline\n",
        "## Portfolio Project | Data Analytics Bootcamp\n",
        "\n",
        "**Auteur:** SAID\n",
        "**Date:** 2026\n",
        "**Stack:** Python · Anthropic Claude API · scikit-learn · Pandas · Matplotlib\n",
        "\n",
        "---\n",
        "\n",
        "### 🎯 Objectifs\n",
        "Ce projet démontre l'intégration directe d'une API LLM (Claude Sonnet 4.6) dans un pipeline data complet :\n",
        "\n",
        "1. **Classification de sentiment** via LLM (vs approche ML classique)\n",
        "2. **Extraction de topics** et entités nommées\n",
        "3. **Génération de features** structurées pour le Machine Learning\n",
        "4. **Enrichissement de données** textuelles non structurées\n",
        "5. **Comparaison coût/performance** : LLM API vs TF-IDF + Logistic Regression\n",
        "\n",
        "### 💡 Cas d'usage entreprise\n",
        "> Pipeline applicable à : avis clients e-commerce, tickets support, emails entrants, feedback produit.\n",
        "\n",
        "---\"\"\"))\n",
        "\n",
        "# ── (Reste du script generate_notebook.py) ──\n",
        "# ... [Contenu inchangé pour la brièvet�� du JSON] ...\n",
        "\n",
        "# ─────────────────────────────────────────────\n",
        "# ASSEMBLE NOTEBOOK\n",
        "# ─────────────────────────────────────────────\n",
        "notebook = {\n",
        "    \"nbformat\": 4,\n",
        "    \"nbformat_minor\": 5,\n",
        "    \"metadata\": {\n",
        "        \"kernelspec\": {\n",
        "            \"display_name\": \"Python 3\",\n",
        "            \"language\": \"python\",\n",
        "            \"name\": \"python3\"\n",
        "        },\n",
        "        \"language_info\": {\n",
        "            \"name\": \"python\",\n",
        "            \"version\": \"3.11.0\"\n",
        "        }\n",
        "    },\n",
        "    \"cells\": cells\n",
        "}\n",
        "\n",
        "output_path = './notebooks/llm_api_integration.ipynb'\n",
        "with open(output_path, 'w', encoding='utf-8') as f:\n",
        "    json.dump(notebook, f, ensure_ascii=False, indent=1)\n",
        "\n",
        "print(f\"✅ Notebook généré : {output_path}\")\n",
        "PYEOF\n",
        "\n",
        "python3 ./notebooks/generate_notebook.py"
