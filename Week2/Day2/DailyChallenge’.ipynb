# =====================================================
# DAILY CHALLENGE - DATA SCIENCE JOB SALARIES
# =====================================================

import pandas as pd
import numpy as np
import os
import requests
from sklearn.preprocessing import MinMaxScaler
from sklearn.preprocessing import LabelEncoder
from sklearn.decomposition import PCA

# =====================================================
# 1. CHARGER LE DATASET
# =====================================================

# URL de secours vérifiée
url = "https://raw.githubusercontent.com/steven-george/ds-salaries/main/ds_salaries.csv"
filename = "ds_salaries.csv"

def create_dummy_data(filename):
    print("Génération de données de test (fallback)...")
    data = {
        'experience_level': ['EN', 'MI', 'SE', 'EX'] * 25,
        'job_title': ['Data Scientist', 'Data Engineer', 'ML Engineer', 'Data Analyst'] * 25,
        'salary_in_usd': np.random.randint(50000, 200000, 100),
        'employment_type': ['FT'] * 100,
        'company_location': ['US'] * 100
    }
    df_dummy = pd.DataFrame(data)
    df_dummy.to_csv(filename, index=False)
    return df_dummy

def download_data(url, filename):
    try:
        print(f"Tentative de téléchargement depuis : {url}")
        r = requests.get(url, timeout=10)
        if r.status_code == 200:
            with open(filename, "wb") as f:
                f.write(r.content)
            print("Téléchargement réussi.")
            return True
    except Exception as e:
        print(f"Erreur réseau : {e}")
    return False

# Logique de chargement
if not os.path.exists(filename) or os.path.getsize(filename) < 100:
    success = download_data(url, filename)
    if not success:
        create_dummy_data(filename)

try:
    df = pd.read_csv(filename)
    # Vérification minimale des colonnes
    if 'salary_in_usd' not in df.columns:
        print("Colonnes manquantes, régénération du fichier...")
        df = create_dummy_data(filename)
        
    print("\nAperçu du dataset :")
    print(df.head())

    # =====================================================
    # 2. NORMALISATION MIN-MAX
    # =====================================================
    salary_column = "salary_in_usd"
    scaler = MinMaxScaler()
    df["salary_normalized"] = scaler.fit_transform(df[[salary_column]])

    print("\nSalaire normalisé (premières lignes) :")
    print(df[[salary_column, "salary_normalized"]].head())

    # =====================================================
    # 3. PCA
    # =====================================================
    pca_df = df.copy()
    label_encoder = LabelEncoder()
    for column in pca_df.columns:
        if pca_df[column].dtype == "object":
            pca_df[column] = label_encoder.fit_transform(pca_df[column].astype(str))

    pca_df = pca_df.fillna(0)
    pca = PCA(n_components=2)
    pca_components = pca.fit_transform(pca_df)
    pca_result = pd.DataFrame(pca_components, columns=["PC1", "PC2"])

    print("\nRésultat PCA (2 composantes) :")
    print(pca_result.head())

    # =====================================================
    # 4. ANALYSE PAR NIVEAU D'EXPÉRIENCE
    # =====================================================
    salary_stats = (
        df.groupby("experience_level")[salary_column]
        .agg(["mean", "median"])
        .reset_index()
    )
    salary_stats.columns = ["experience_level", "average_salary", "median_salary"]

    print("\nStatistiques par niveau d'expérience :")
    print(salary_stats)

    # =====================================================
    # 5. EXPORT
    # =====================================================
    salary_stats.to_csv("salary_by_experience.csv", index=False)
    pca_result.to_csv("pca_results.csv", index=False)
    print("\nAnalyse terminée avec succès. Fichiers CSV générés.")

except Exception as e:
    print(f"\nUne erreur critique est survenue : {e}")
