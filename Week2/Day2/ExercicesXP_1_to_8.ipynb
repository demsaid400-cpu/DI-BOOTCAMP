# ============================================================
# EXERCICE 2 : Statistiques descriptives
# ============================================================
print("\n" + "=" * 60)
print("EXERCICE 2 : Statistiques descriptives")
print("=" * 60)

# Données de l'exercice
data_ex2 = [12, 15, 13, 12, 18, 20, 22, 21]
print(f"Données : {data_ex2}")

# Calcul avec scipy.stats
mean_val   = stats.tmean(data_ex2)
median_val = np.median(data_ex2)          # scipy n'a pas de fonction median directe
var_val    = stats.tvar(data_ex2)         # variance non biaisée (ddof=1)
std_val    = stats.tstd(data_ex2)         # écart-type non biaisé (ddof=1)
mode_val   = stats.mode(data_ex2, keepdims=True)

print(f"\nRésultats avec scipy.stats :")
print(f"  Moyenne        : {mean_val:.2f}")
print(f"  Médiane        : {median_val:.2f}")
print(f"  Variance       : {var_val:.2f}")
print(f"  Écart-type     : {std_val:.2f}")
print(f"  Mode           : {mode_val.mode[0]} (apparaît {mode_val.count[0]} fois)")

# Application sur le dataset salaires
salaries = df['salary'].values
print(f"\nStatistiques des salaires du dataset :")
print(f"  Moyenne        : ${stats.tmean(salaries):,.2f}")
print(f"  Médiane        : ${np.median(salaries):,.2f}")
print(f"  Variance       : ${stats.tvar(salaries):,.2f}")
print(f"  Écart-type     : ${stats.tstd(salaries):,.2f}")
desc = stats.describe(salaries)
print(f"  Min / Max      : ${desc.minmax[0]:,} / ${desc.minmax[1]:,}")
print(f"  Asymétrie      : {desc.skewness:.4f}")
print(f"  Kurtosis       : {desc.kurtosis:.4f}")


# ============================================================
# EXERCICE 3 : Comprendre les distributions
# ============================================================
print("\n" + "=" * 60)
print("EXERCICE 3 : Distribution normale")
print("=" * 60)

from scipy.stats import norm

mu, sigma = 50, 10
x = np.linspace(mu - 4*sigma, mu + 4*sigma, 300)
pdf_vals = norm.pdf(x, mu, sigma)
cdf_vals = norm.cdf(x, mu, sigma)

# Calcul de probabilités
p_between = norm.cdf(60, mu, sigma) - norm.cdf(40, mu, sigma)
print(f"Distribution N({mu}, {sigma}²)")
print(f"  P(40 ≤ X ≤ 60) = {p_between:.4f} ({p_between*100:.2f}%)")
print(f"  P(X ≤ 50)      = {norm.cdf(50, mu, sigma):.4f}")
print(f"  95e percentile = {norm.ppf(0.95, mu, sigma):.2f}")

fig, axes = plt.subplots(1, 2, figsize=(12, 4))

# PDF
axes[0].plot(x, pdf_vals, 'b-', linewidth=2, label='PDF')
axes[0].fill_between(x, pdf_vals,
                     where=(x >= 40) & (x <= 60),
                     alpha=0.3, color='blue', label='P(40≤X≤60)')
axes[0].axvline(mu, color='red', linestyle='--', label=f'μ={mu}')
axes[0].set_title(f'Distribution Normale N({mu}, {sigma}²) — PDF')
axes[0].set_xlabel('Valeur')
axes[0].set_ylabel('Densité de probabilité')
axes[0].legend()
axes[0].grid(True, alpha=0.3)

# CDF
axes[1].plot(x, cdf_vals, 'g-', linewidth=2)
axes[1].axhline(0.5, color='red', linestyle='--', label='50%')
axes[1].set_title(f'Distribution Normale N({mu}, {sigma}²) — CDF')
axes[1].set_xlabel('Valeur')
axes[1].set_ylabel('Probabilité cumulée')
axes[1].legend()
axes[1].grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig('/mnt/user-data/outputs/ex3_distribution_normale.png', dpi=150, bbox_inches='tight')
plt.close()
print("  → Graphique sauvegardé : ex3_distribution_normale.png")


# ============================================================
# EXERCICE 4 : Test T
# ============================================================
print("\n" + "=" * 60)
print("EXERCICE 4 : Test T")
print("=" * 60)

np.random.seed(42)
data1 = np.random.normal(50, 10, 100)
data2 = np.random.normal(60, 10, 100)

# Test T pour échantillons indépendants
t_stat, p_value = stats.ttest_ind(data1, data2)
print(f"Test T (données simulées) :")
print(f"  Moyenne data1 : {np.mean(data1):.2f}")
print(f"  Moyenne data2 : {np.mean(data2):.2f}")
print(f"  Statistique T : {t_stat:.4f}")
print(f"  Valeur P      : {p_value:.6f}")
print(f"  Conclusion    : {'Différence significative (p < 0.05)' if p_value < 0.05 else 'Pas de différence significative'}")

# Application au dataset : Test T Senior vs Mid salaires
senior_salaries = df[df['experience_level'] == 'Senior']['salary'].values
mid_salaries    = df[df['experience_level'] == 'Mid']['salary'].values

t_stat2, p_value2 = stats.ttest_ind(senior_salaries, mid_salaries)
print(f"\nTest T sur salaires Senior vs Mid (dataset) :")
print(f"  Moyenne Senior : ${np.mean(senior_salaries):,.2f} (n={len(senior_salaries)})")
print(f"  Moyenne Mid    : ${np.mean(mid_salaries):,.2f} (n={len(mid_salaries)})")
print(f"  Statistique T  : {t_stat2:.4f}")
print(f"  Valeur P       : {p_value2:.6f}")
print(f"  Conclusion     : {'Différence significative (p < 0.05)' if p_value2 < 0.05 else 'Pas de différence significative'}")


# ============================================================
# EXERCICE 5 : Régression linéaire
# ============================================================
print("\n" + "=" * 60)
print("EXERCICE 5 : Régression linéaire")
print("=" * 60)

from scipy.stats import linregress

house_sizes  = np.array([50, 70, 80, 100, 120])
house_prices = np.array([150000, 200000, 210000, 250000, 280000])

slope, intercept, r_value, p_value_reg, std_err = linregress(house_sizes, house_prices)

print(f"Résultats de la régression linéaire :")
print(f"  Pente (slope)      : {slope:.2f} unités/m²")
print(f"  Intersection       : {intercept:.2f}")
print(f"  R²                 : {r_value**2:.4f}")
print(f"  Valeur P           : {p_value_reg:.6f}")
print(f"  Erreur standard    : {std_err:.2f}")

# Prédiction pour 90 m²
size_predict = 90
predicted_price = slope * size_predict + intercept
print(f"\nPrédiction pour {size_predict} m² :")
print(f"  Prix prédit        : {predicted_price:,.2f}")

print(f"\nInterprétation :")
print(f"  Chaque m² supplémentaire augmente le prix d'environ {slope:,.2f} unités.")
print(f"  Le modèle explique {r_value**2*100:.1f}% de la variance des prix.")

# Visualisation
x_line = np.linspace(40, 130, 100)
y_line = slope * x_line + intercept

fig, ax = plt.subplots(figsize=(8, 5))
ax.scatter(house_sizes, house_prices, color='blue', zorder=5, s=80, label='Données réelles')
ax.plot(x_line, y_line, 'r-', linewidth=2, label=f'Régression (R²={r_value**2:.3f})')
ax.scatter([size_predict], [predicted_price], color='green', zorder=6, s=120,
           marker='*', label=f'Prédiction 90m²: {predicted_price:,.0f}')
ax.set_xlabel('Taille (m²)')
ax.set_ylabel('Prix')
ax.set_title('Régression Linéaire — Prix des maisons')
ax.legend()
ax.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig('/mnt/user-data/outputs/ex5_regression_lineaire.png', dpi=150, bbox_inches='tight')
plt.close()
print("  → Graphique sauvegardé : ex5_regression_lineaire.png")

# Application au dataset : taille d'expérience vs salaire
# Encoder experience_level numériquement
exp_map = {'Entry': 1, 'Mid': 2, 'Senior': 3, 'Executive': 4}
df['exp_numeric'] = df['experience_level'].map(exp_map)
df_reg = df.dropna(subset=['exp_numeric'])

slope_ds, intercept_ds, r_val_ds, p_val_ds, _ = linregress(
    df_reg['exp_numeric'], df_reg['salary'])
print(f"\nRégression sur le dataset (niveau → salaire) :")
print(f"  Pente     : ${slope_ds:,.2f} par niveau")
print(f"  R²        : {r_val_ds**2:.4f}")
print(f"  Valeur P  : {p_val_ds:.6f}")


# ============================================================
# EXERCICE 6 : ANOVA
# ============================================================
print("\n" + "=" * 60)
print("EXERCICE 6 : ANOVA")
print("=" * 60)

from scipy.stats import f_oneway

fertilizer_1 = [5, 6, 7, 6, 5]
fertilizer_2 = [7, 8, 7, 9, 8]
fertilizer_3 = [4, 5, 4, 3, 4]

f_stat, p_value_anova = f_oneway(fertilizer_1, fertilizer_2, fertilizer_3)

print(f"Résultats de l'ANOVA (engrais) :")
print(f"  Moyenne Engrais 1 : {np.mean(fertilizer_1):.2f} cm")
print(f"  Moyenne Engrais 2 : {np.mean(fertilizer_2):.2f} cm")
print(f"  Moyenne Engrais 3 : {np.mean(fertilizer_3):.2f} cm")
print(f"  Valeur F          : {f_stat:.4f}")
print(f"  Valeur P          : {p_value_anova:.6f}")
print(f"  Conclusion        : {'Les engrais ont des effets significativement différents (p < 0.05)' if p_value_anova < 0.05 else 'Pas de différence significative'}")
print(f"\n  Si p > 0.05 : on ne pourrait pas rejeter H₀ (les moyennes seraient")
print(f"  considérées comme égales), indiquant que les engrais n'ont pas")
print(f"  d'effets statistiquement différents sur la croissance.")

# Application au dataset : ANOVA sur salaires par niveau d'expérience
groups = [df[df['experience_level'] == lvl]['salary'].values
          for lvl in ['Entry', 'Mid', 'Senior'] if len(df[df['experience_level'] == lvl]) > 0]
f_stat_ds, p_val_ds = f_oneway(*groups)
print(f"\nANOVA sur salaires par niveau d'expérience (dataset) :")
print(f"  Valeur F : {f_stat_ds:.4f}")
print(f"  Valeur P : {p_val_ds:.6f}")
print(f"  Conclusion : {'Différences significatives entre niveaux' if p_val_ds < 0.05 else 'Pas de différence significative'}")


