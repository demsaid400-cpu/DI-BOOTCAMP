# EXERCICE 7 : Distribution binomiale (optionnel)
# ============================================================
print("\n" + "=" * 60)
print("EXERCICE 7 : Distribution binomiale (optionnel)")
print("=" * 60)

from scipy.stats import binom

n, p_coin = 10, 0.5  # 10 lancers, probabilité 0.5

# Probabilité d'exactement 5 têtes
prob_exact_5 = binom.pmf(5, n, p_coin)
print(f"Lancer de pièce — n={n}, p={p_coin}")
print(f"  P(X = 5)    : {prob_exact_5:.4f} ({prob_exact_5*100:.2f}%)")
print(f"  P(X ≤ 5)    : {binom.cdf(5, n, p_coin):.4f}")
print(f"  P(X ≥ 5)    : {1 - binom.cdf(4, n, p_coin):.4f}")
print(f"  E[X] = n·p  : {n*p_coin}")
print(f"  Var[X]      : {n*p_coin*(1-p_coin)}")

# Distribution complète
k_vals = np.arange(0, n+1)
pmf_vals = binom.pmf(k_vals, n, p_coin)
print(f"\nDistribution complète :")
for k, prob in zip(k_vals, pmf_vals):
    bar = '█' * int(prob * 100)
    print(f"  P(X={k:2d}) = {prob:.4f} {bar}")

fig, ax = plt.subplots(figsize=(8, 4))
ax.bar(k_vals, pmf_vals, color='steelblue', alpha=0.8, edgecolor='black')
ax.bar([5], [pmf_vals[5]], color='red', alpha=0.8, edgecolor='black', label='k=5')
ax.set_xlabel('Nombre de succès (têtes)')
ax.set_ylabel('Probabilité')
ax.set_title(f'Distribution Binomiale B({n}, {p_coin})')
ax.legend()
ax.grid(True, alpha=0.3, axis='y')
plt.tight_layout()
plt.savefig('/mnt/user-data/outputs/ex7_binomial.png', dpi=150, bbox_inches='tight')
plt.close()
print("  → Graphique sauvegardé : ex7_binomial.png")


