print("=" * 60)

from scipy.stats import pearsonr, spearmanr

# Données de l'exemple
data_corr = pd.DataFrame({
    'age':    [23, 25, 30, 35, 40],
    'income': [35000, 40000, 50000, 60000, 70000]
})
print("Données exemple :")
print(data_corr.to_string(index=False))

pearson_r,  pearson_p  = pearsonr(data_corr['age'], data_corr['income'])
spearman_r, spearman_p = spearmanr(data_corr['age'], data_corr['income'])

print(f"\nCorr. de Pearson  : r={pearson_r:.4f},  p={pearson_p:.4f}")
print(f"Corr. de Spearman : ρ={spearman_r:.4f},  p={spearman_p:.4f}")
print(f"Interprétation    : Corrélation {'forte' if abs(pearson_r) > 0.7 else 'modérée'} positive")

# Application au dataset : corrélation niveau → salaire
pearson_ds,  p_pear  = pearsonr(df_reg['exp_numeric'], df_reg['salary'])
spearman_ds, p_spear = spearmanr(df_reg['exp_numeric'], df_reg['salary'])

print(f"\nCorr. Pearson  (exp. level vs salary) : r={pearson_ds:.4f}, p={p_pear:.4f}")
print(f"Corr. Spearman (exp. level vs salary) : ρ={spearman_ds:.4f}, p={p_spear:.4f}")

# Matrice de corrélation sur variables numériques du dataset
numeric_cols = df_reg[['salary', 'exp_numeric']].copy()
corr_matrix  = numeric_cols.corr(method='pearson')
print(f"\nMatrice de corrélation (Pearson) :")
