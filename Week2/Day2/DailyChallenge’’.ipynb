df = pd.read_csv("ds_salaries.csv")

print(df.head())
print(df.shape)
print(df.info())

print(df.describe())
print(df.columns)
scaler = MinMaxScaler()

df['salary_normalized'] = scaler.fit_transform(
    df[['salary']]
)

print(
    df[['salary', 'salary_normalized']].head()
)
print(df['salary_normalized'].min())
print(df['salary_normalized'].max())
df_pca = df.copy()

categorical_cols = [
    'experience_level',
    'employment_type',
    'job_title',
    'salary_currency',
    'employee_residence',
    'company_location',
    'company_size'
]

encoder = LabelEncoder()

for col in categorical_cols:
    df_pca[col] = encoder.fit_transform(
        df_pca[col]
    )
features = [
    'work_year',
    'experience_level',
    'employment_type',
    'job_title',
    'salary',
    'salary_in_usd',
    'employee_residence',
    'remote_ratio',
    'company_location',
    'company_size'
]

X = df_pca[features]
pca = PCA(n_components=2)

principal_components = pca.fit_transform(X)

pca_df = pd.DataFrame(
    principal_components,
    columns=['PC1', 'PC2']
)

print(pca_df.head())
print(
    pca.explained_variance_ratio_
)


PC1 explique 78% de la variance
PC2 explique 17% de la variance

Total = 95%

plt.figure(figsize=(8,6))

plt.scatter(
    pca_df['PC1'],
    pca_df['PC2'],
    alpha=0.5
)

plt.title(
    'PCA - Data Science Salaries'
)

plt.xlabel('PC1')
plt.ylabel('PC2')

plt.show()
salary_stats = (
    df.groupby('experience_level')
    ['salary_in_usd']
    .agg(['mean', 'median'])
)

print(salary_stats)
salary_stats['mean'].plot(
    kind='bar',
    figsize=(8,5)
)

plt.title(
    'Average Salary by Experience Level'
)

plt.ylabel('Salary (USD)')
plt.show()
