import pandas as pd
import numpy as np

from sklearn.preprocessing import MinMaxScaler
from sklearn.decomposition import PCA

# Correction du nom du fichier d'après les fichiers présents dans votre session
df = pd.read_csv("datascience_salaries.csv")

print("Dimensions du dataset :", df.shape)
print("\nAperçu des données :")
print(df.head())


print(df.columns)
scaler = MinMaxScaler()

df["salary_normalized"] = scaler.fit_transform(df[["salary"]])

print(df[["salary", "salary_normalized"]].head())
print("Minimum :", df["salary_normalized"].min())
print("Maximum :", df["salary_normalized"].max())
numeric_df = df.select_dtypes(include=np.number)

print(numeric_df.columns)
pca = PCA(n_components=2)

pca_result = pca.fit_transform(numeric_df)

pca_df = pd.DataFrame(
    pca_result,
    columns=["PC1", "PC2"]
)

print(pca_df.head())
print("Variance expliquée :")
print(pca.explained_variance_ratio_)
print("Variance expliquée :")
print(pca.explained_variance_ratio_)
salary_stats = df.groupby("experience_level")["salary"].agg(
    Average_Salary="mean",
    Median_Salary="median"
)

print(salary_stats)
experience_map = {
    "EN": "Junior",
    "MI": "Mid-Level",
    "SE": "Senior",
    "EX": "Executive"
}

salary_stats.index = salary_stats.index.map(experience_map)

print(salary_stats)
