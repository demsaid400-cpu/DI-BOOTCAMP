def dashboard():
    fig, axs = plt.subplots(2, 2, figsize=(15, 10))

    # Sales trend
    df.groupby('Order Year')['Sales'].sum().plot(ax=axs[0,0])
    axs[0,0].set_title("Yearly Sales")

    # Category
    df.groupby('Category')['Sales'].sum().plot(kind='bar', ax=axs[0,1])
    axs[0,1].set_title("Category Sales")

    # States
    state_sales.tail(10).plot(kind='barh', ax=axs[1,0])
    axs[1,0].set_title("Top States")

    # Discount vs Profit
    sns.scatterplot(data=df, x='Discount', y='Profit', ax=axs[1,1], alpha=0.5)
    axs[1,1].set_title("Discount vs Profit")

    plt.tight_layout()
    plt.show()

dashboard()

## Key Business Insights

- High discounts (>20%) significantly increase loss probability
- Sales are concentrated in a small number of states
- Technology category shows strongest profitability
- Some products generate high sales but negative profit margins

## Recommendations

- Limit discounts to below 20% for profitability
- Focus expansion in top-performing states
- Review low-margin products for pricing optimization

