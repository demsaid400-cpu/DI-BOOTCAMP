import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# Chargement du fichier
df = pd.read_csv('/content/Student Mental health.csv')

# Nettoyage rapide des espaces dans les noms de colonnes
df.columns = df.columns.str.strip()

# 1. Distribution du CGPA
plt.figure(figsize=(8, 4))
sns.histplot(data=df, x='What is your CGPA?', color='purple', kde=False)
plt.title("Distribution du CGPA des étudiants", fontsize=14)
plt.xticks(rotation=45)
plt.show()

# 2. Proportion d'anxiété par genre
# Note: 'Do you have Anxiety?' contient 'Yes'/'No'. 
# On peut utiliser countplot pour visualiser les fréquences.
plt.figure(figsize=(7, 4))
sns.countplot(data=df, x='Choose your gender', hue='Do you have Anxiety?', palette='pastel')
plt.title("Anxiété par genre chez les étudiants", fontsize=14)
plt.show()

# 3. Relation entre l'Âge et les Crises de Panique (CORRECTION DU NOM DE COLONNE)
# Correction : 'Do you have Panic attack?' au lieu de 'Attacks'
df['Panic_Numeric'] = df['Do you have Panic attack?'].map({'Yes': 1, 'No': 0})

plt.figure(figsize=(8, 4))
sns.scatterplot(data=df, x='Age', y='Panic_Numeric', alpha=0.7, color='red', s=100, marker='X')
plt.title("Relation entre l'Âge et les Crises de Panique", fontsize=14)
plt.xlabel("Age")
plt.ylabel("Panic Attacks (1 = Yes, 0 = No)")
plt.yticks([0, 1], ['No (0)', 'Yes (1)'])
plt.grid(True, linestyle=':', alpha=0.6)
plt.show()
