import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from scipy import stats
import os

file_path = "/content/Airplane_Crashes_and_Fatalities_Since_1908_t0_2023.csv"

if os.path.exists(file_path):
    try:
        df = pd.read_csv(file_path, encoding='latin1')
        print("--- Aperçu des données ---")
        display(df.head())
        print("\n--- Informations sur le dataset ---")
        print(df.info())
    except Exception as e:
        print(f"Une erreur est survenue lors de la lecture : {e}")
else:
    print(f"Erreur : Le fichier '{file_path}' est introuvable.")
    
df.columns = df.columns.str.lower().str.replace(" ", "_")

df['date'] = pd.to_datetime(df['date'], errors='coerce')

df['year'] = df['date'].dt.year

df['fatalities'] = pd.to_numeric(df['fatalities'], errors='coerce')
df['aboard'] = pd.to_numeric(df['aboard'], errors='coerce')

df['fatalities'] = df['fatalities'].fillna(0)
df['aboard'] = df['aboard'].fillna(0)

df['survival_rate'] = (df['aboard'] - df['fatalities']) / df['aboard']
df['survival_rate'] = df['survival_rate'].replace([np.inf, -np.inf], np.nan).fillna(0)
print("Total crashes:", len(df))
print("Total fatalities:", df['fatalities'].sum())
print("Average fatalities per crash:", df['fatalities'].mean())
print("Median fatalities:", df['fatalities'].median())
crashes_per_year = df.groupby('year').size()

plt.figure(figsize=(12,5))
plt.plot(crashes_per_year.index, crashes_per_year.values)
plt.title("Airplane Crashes Over Time")
plt.xlabel("Year")
plt.ylabel("Number of Crashes")
plt.grid()
plt.show()
print("Mean fatalities:", np.mean(df['fatalities']))
print("Median fatalities:", np.median(df['fatalities']))
print("Std deviation:", np.std(df['fatalities']))
print("Mean fatalities:", np.mean(df['fatalities']))
print("Median fatalities:", np.median(df['fatalities']))
print("Std deviation:", np.std(df['fatalities']))
df['decade'] = (df['year'] // 10) * 10

fatal_80s = df[df['decade'] == 1980]['fatalities']
fatal_2000s = df[df['decade'] == 2000]['fatalities']

t_stat, p_value = stats.ttest_ind(fatal_80s, fatal_2000s, nan_policy='omit')

print("T-statistic:", t_stat)
print("P-value:", p_value)

if p_value < 0.05:
    print("Significant difference in fatalities between decades")
else:
    print("No significant difference between decades")
    plt.figure(figsize=(8,5))
plt.hist(df['fatalities'], bins=30)
plt.title("Distribution of Fatalities per Crash")
plt.xlabel("Fatalities")
plt.ylabel("Frequency")
plt.show()
crashes_decade = df['decade'].value_counts().sort_index()

plt.figure(figsize=(10,5))
plt.bar(crashes_decade.index, crashes_decade.values)
plt.title("Crashes by Decade")
plt.xlabel("Decade")
plt.ylabel("Number of Crashes")
plt.show()
survival_trend = df.groupby('year')['survival_rate'].mean()

plt.figure(figsize=(12,5))
plt.plot(survival_trend.index, survival_trend.values)
plt.title("Survival Rate Over Time")
plt.xlabel("Year")
plt.ylabel("Survival Rate")
plt.grid()
plt.show()


INSIGHTS & INTERPRETATION

Key findings

1. Crash frequency trend

* Early aviation years → very high crash frequency
* Modern aviation → strong decline due to safety improvements

⸻

2. Fatalities distribution

* Highly skewed distribution
* Majority of crashes have low fatalities
* Few extreme disasters dominate total deaths

⸻

3. Statistical test result

* If p < 0.05:
    Fatalities differ significantly across decades
* If p > 0.05:
    No statistically significant difference

⸻

4. Safety evolution insight

* Survival rate improves over time
* Aviation becomes safer due to:
    * better technology
    * regulations
    * training improvements

⸻

 FINAL CONCLUSION

The dataset shows a clear long-term improvement in aviation safety:

* ↓ crashes over decades
* ↑ survival rate
* Strong variability in catastrophic events
