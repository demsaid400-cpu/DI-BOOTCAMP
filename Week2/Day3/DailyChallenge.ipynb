import pandas as pd
import numpy as np
import scipy.stats as stats
import matplotlib.pyplot as plt
import seaborn as sns

# 1. Chargement des données avec gestion des erreurs de formatage
file_path = "/content/Airplane_Crashes_and_Fatalities_Since_1908_t0_2023 2.csv"
try:
    df = pd.read_csv(file_path, encoding='latin1', on_bad_lines='skip', engine='python')
    print("Données chargées avec succès.")
except Exception as e:
    print(f"Erreur lors du chargement : {e}")

# Affichage des premières lignes
if 'df' in locals():
    display(df.head())

    # 2. Nettoyage rapide
    if 'Fatalities' in df.columns:
        df = df.dropna(subset=['Fatalities'])

    # 3. Analyse statistique
    stat_summary = df.describe()
    display(stat_summary)

    # 4. Visualisation
    # On tente de convertir la Date si elle existe
    if 'Date' in df.columns:
        df['Date'] = pd.to_datetime(df['Date'], errors='coerce')
        df['Year'] = df['Date'].dt.year

    if 'Year' in df.columns:
        plt.figure(figsize=(10, 6))
        sns.histplot(df['Year'].dropna(), bins=30, kde=True)
        plt.title("Distribution des crashs d'avions par année")
        plt.show()
    

# 5. Analyse Statistique Avancée avec SciPy
print("--- ANALYSE STATISTIQUE AVEC SCIPY ---")

# Vérification de la présence des colonnes nécessaires
if 'Fatalities' in df.columns and 'Aboard' in df.columns:
    # Nettoyage des valeurs manquantes spécifiques pour le test
    stats_df = df[['Fatalities', 'Aboard']].dropna()
    
    # Calcul du coefficient de corrélation de Pearson et de la p-value
    corr_coef, p_value = stats.pearsonr(stats_df['Aboard'], stats_df['Fatalities'])
    
    print(f"Coefficient de corrélation de Pearson : {corr_coef:.4f}")
    print(f"P-value : {p_value}")
    
    # Interprétation du test statistique
    if p_value < 0.05:
        print("Conclusion : Il existe une corrélation statistiquement significative entre le nombre de personnes à bord et le nombre de fatalités.")
    else:
        print("Conclusion : Pas de corrélation statistiquement significative démontrée.")
        
    # Test de normalité (Shapiro-Wilk) sur les fatalités
    # Note : Sur un grand échantillon, on utilise souvent une approximation ou un sous-échantillon
    shapiro_stat, shapiro_p = stats.shapiro(stats_df['Fatalities'].sample(norm_sample := min(500, len(stats_df))))
    print(f"\nTest de normalité de Shapiro-Wilk (sur un échantillon de {norm_sample}) :")
    print(f"Statistique : {shapiro_stat:.4f}, P-value : {shapiro_p}")
else:
    print("Les colonnes 'Fatalities' ou 'Aboard' sont manquantes pour l'analyse SciPy.")
