import scipy

print("SciPy Version:", scipy.__version__)
from scipy import stats
import numpy as np

data = [12, 15, 13, 12, 18, 20, 22, 21]

mean_value = np.mean(data)
median_value = np.median(data)
variance_value = np.var(data, ddof=1)
std_value = np.std(data, ddof=1)

print("Mean:", mean_value)
print("Median:", median_value)
print("Variance:", variance_value)
print("Standard Deviation:", std_value)
from scipy.stats import norm
import matplotlib.pyplot as plt
import numpy as np

x = np.linspace(-4, 4, 100)

y = norm.pdf(x, loc=0, scale=1)

plt.plot(x, y)
plt.title("Normal Distribution")
plt.xlabel("X")
plt.ylabel("Probability Density")
plt.show()
from scipy.stats import norm

probability = norm.cdf(1.5)

print("Probability:", probability)
from scipy.stats import linregress
import pandas as pd
import matplotlib.pyplot as plt

house_data = pd.DataFrame({
    "Size":[1000,1500,2000,2500,3000],
    "Price":[200000,250000,300000,350000,400000]
})

x = house_data["Size"]
y = house_data["Price"]

result = linregress(x, y)

print("Slope:", result.slope)
print("Intercept:", result.intercept)
print("R-squared:", result.rvalue**2)
print("P-value:", result.pvalue)
plt.scatter(x, y)

plt.plot(
    x,
    result.intercept + result.slope*x
)

plt.xlabel("House Size")
plt.ylabel("House Price")
plt.title("Linear Regression")

plt.show()


Positive linear relationship:
larger houses tend to have higher prices.

from scipy.stats import ttest_ind

group_A = [25, 30, 28, 35, 29]
group_B = [40, 42, 38, 45, 41]

t_stat, p_value = ttest_ind(group_A, group_B)

print("T-statistic:", t_stat)
print("P-value:", p_value)


if p_value < 0.05:

    print("Significant difference between groups")
else:
    print("No significant difference")

from scipy.stats import f_oneway

group1 = [22, 24, 23, 25, 27]
group2 = [30, 29, 31, 28, 32]
group3 = [40, 42, 41, 39, 43]

f_stat, p_value = f_oneway(
    group1,
    group2,
    group3
)

print("F-statistic:", f_stat)
print("P-value:", p_value)


if p_value < 0.05:

    print("At least one group differs significantly")
else:
    print("No significant difference")

from scipy.stats import chi2_contingency
import numpy as np

table = np.array([
    [20, 30],
    [15, 35]
])

chi2, p, dof, expected = chi2_contingency(table)

print("Chi-square:", chi2)
print("P-value:", p)
print("Degrees of Freedom:", dof)

print("\nExpected Frequencies:")
print(expected)

if p < 0.05:

    print("Variables are associated")
else:
    print("Variables are independent")
