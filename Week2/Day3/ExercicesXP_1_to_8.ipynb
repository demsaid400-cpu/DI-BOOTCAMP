import pandas as pd
import numpy as np

from sklearn.preprocessing import MinMaxScaler
from sklearn.preprocessing import LabelEncoder
from sklearn.decomposition import PCA
import matplotlib.pyplot as plt
df = pd.read_csv("datascience_salaries.csv")

print(df.head())
print(df.shape)
print(df.info())

print(df.describe())
print(df.columns)
scaler = MinMaxScaler()

df['salary_normalized'] = scaler.fit_transform(
    df[['salary']]
)

print(
    df[['salary', 'salary_normalized']].head()
)
print(df['salary_normalized'].min())
print(df['salary_normalized'].max())
df_pca = df.copy()

# Updated list to match the columns actually present in the dataframe
categorical_cols = [
    'experience_level',
    'job_type',
    'job_title',
    'salary_currency',
    'location'
]

encoder = LabelEncoder()

for col in categorical_cols:
    df_pca[col] = encoder.fit_transform(
        df_pca[col]
    )


from sklearn.preprocessing import StandardScaler

features = [
    'job_title',
    'job_type',
    'experience_level',
    'location',
    'salary_currency',
    'salary'
]

# Il est crucial de standardiser les données pour la PCA
X = df_pca[features]
X_scaled = StandardScaler().fit_transform(X)

pca = PCA(n_components=2)
principal_components = pca.fit_transform(X_scaled)

pca_df = pd.DataFrame(
    principal_components,
    columns=['PC1', 'PC2']
)

print("Premières lignes de la PCA (données scalées) :")
print(pca_df.head())
print("\nRatio de variance expliquée :")
print(pca.explained_variance_ratio_)

plt.figure(figsize=(8,6))
plt.scatter(pca_df['PC1'], pca_df['PC2'], alpha=0.5)
plt.title('PCA - Data Science Salaries (Standardized)')
plt.xlabel(f"PC1 ({pca.explained_variance_ratio_[0]:.2%})")
plt.ylabel(f"PC2 ({pca.explained_variance_ratio_[1]:.2%})")
plt.grid(True)
plt.show()

salary_stats = (
    df.groupby('experience_level')
    ['salary']
    .agg(['mean', 'median'])
)

print("\nStatistiques de salaire par niveau d'expérience :")
print(salary_stats)
salary_stats['mean'].plot(
    kind='bar',
    figsize=(8,5)
)

plt.title(
    'Average Salary by Experience Level'
)

plt.ylabel('Salary (USD)')
plt.show()

### Analyse de la Variance Expliquée
Après correction (normalisation des données), les ratios de variance seront plus équilibrés.

Insight 1

La normalisation Min-Max a converti toutes les valeurs de salaire dans l’intervalle [0,1], ce qui facilite l’entraînement des modèles de machine learning.

Insight 2

La PCA a réduit les 10 variables à seulement 2 composantes principales tout en conservant la majorité de l’information du dataset.

Insight 3

Les salaires augmentent fortement avec l’expérience :
