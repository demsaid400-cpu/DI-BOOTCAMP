import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Load dataset using the correct excel file found in /content/
file_path = '/content/US Superstore data.xls'
df = pd.read_excel(file_path)

# Convert date columns
df['Order Date'] = pd.to_datetime(df['Order Date'])
df['Ship Date'] = pd.to_datetime(df['Ship Date'])

# Check missing values
print("Missing Values:")
print(df.isnull().sum())

# Check duplicates
print("\nDuplicates:", df.duplicated().sum())

# Dataset information
df.info()

# Display first few rows
display(df.head())


state_sales = (
    df.groupby('State')['Sales']
      .sum()
      .sort_values(ascending=False)
)

plt.figure(figsize=(12,6))
sns.barplot(
    x=state_sales.head(10).values,
    y=state_sales.head(10).index
)

plt.title("Top 10 States by Sales")
plt.xlabel("Total Sales")
plt.ylabel("State")
plt.show()

print(state_sales.head(10))


Insight

Identify the states generating the highest revenue and prioritize them for marketing investments.

ny_ca = (
    df[df['State'].isin(['New York', 'California'])]
      .groupby('State')[['Sales','Profit']]
      .sum()
)

print(ny_ca)

ny_ca.plot(
    kind='bar',
    figsize=(8,5)
)

plt.title("New York vs California")
plt.ylabel("Amount ($)")
plt.show()
ny_ca['Profit Margin (%)'] = (
    ny_ca['Profit'] / ny_ca['Sales']
) * 100

print(ny_ca)
ny_customers = (
    df[df['State'] == 'New York']
      .groupby('Customer Name')
      .agg({
          'Sales':'sum',
          'Profit':'sum'
      })
      .sort_values('Sales', ascending=False)
)

print(ny_customers.head(10))
plt.figure(figsize=(10,6))

sns.barplot(
    x=ny_customers.head(10)['Sales'],
    y=ny_customers.head(10).index
)

plt.title("Top Customers in New York")
plt.xlabel("Sales")
plt.show()

The customer ranked first can be considered the outstanding customer.

state_profit = (
    df.groupby('State')
      .agg({
          'Sales':'sum',
          'Profit':'sum'
      })
)

state_profit['Profit Margin (%)'] = (
    state_profit['Profit'] /
    state_profit['Sales']
) * 100

state_profit = state_profit.sort_values(
    'Profit Margin (%)',
    ascending=False
)

print(state_profit.head(15))
plt.figure(figsize=(12,6))

sns.barplot(
    x=state_profit.head(15)['Profit Margin (%)'],
    y=state_profit.head(15).index
)

plt.title("Most Profitable States")
plt.show()

Insight

Some states may generate high sales but low profit margins due to discounts and operational costs.

customer_profit = (
    df.groupby('Customer Name')['Profit']
      .sum()
      .sort_values(ascending=False)
)

pareto_profit = customer_profit.reset_index()

pareto_profit['Cumulative Profit'] = (
    pareto_profit['Profit'].cumsum()
)

pareto_profit['Cumulative %'] = (
    pareto_profit['Cumulative Profit']
    / pareto_profit['Profit'].sum()
) * 100

pareto_profit['Customer %'] = (
    np.arange(1, len(pareto_profit)+1)
    / len(pareto_profit)
) * 100
plt.figure(figsize=(10,6))

plt.plot(
    pareto_profit['Customer %'],
    pareto_profit['Cumulative %']
)

plt.axhline(80, linestyle='--')
plt.axvline(20, linestyle='--')

plt.title("Pareto Analysis: Profit")
plt.xlabel("% of Customers")
plt.ylabel("% of Cumulative Profit")

plt.show()

Conclusion

If the curve reaches 80% profit before 20% of customers, the Pareto Principle holds.

