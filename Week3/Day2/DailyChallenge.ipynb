import requests
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import zipfile
import io
from scipy import stats

# Configuration de l'API
response = requests.get(
    "https://datasets.wri.org/api/3/action/package_show?id=global-power-plant-database",
)
data = response.json()

# Extraction de l'URL du fichier (format ZIP d'après les métadonnées)
zip_url = ""
if data['success']:
    for resource in data['result']['resources']:
        if resource['format'].lower() == 'zip':
            zip_url = resource['url']
            break

sns.set_theme()

if zip_url:
    print(f"Téléchargement de l'archive depuis : {zip_url}")
    r = requests.get(zip_url)
    z = zipfile.ZipFile(io.BytesIO(r.content))
    # Liste des fichiers dans le ZIP
    csv_files = [f for f in z.namelist() if f.endswith('.csv')]
    
    if csv_files:
        print(f"Fichier trouvé dans l'archive : {csv_files[0]}")
        df = pd.read_csv(z.open(csv_files[0]), low_memory=False)
        print(f"Données chargées avec succès : {df.shape}")
        display(df.head())
    else:
        print("Aucun fichier CSV trouvé dans l'archive ZIP.")
else:
    print("Impossible de trouver l'URL du fichier ZIP dans les métadonnées.")

# 1. Data Import and Cleaning

# Identification des valeurs manquantes
missing_values = df.isnull().sum()
print("Valeurs manquantes par colonne :\n", missing_values[missing_values > 0])

# Suppression des colonnes avec trop de valeurs manquantes si nécessaire
# ou remplissage par des valeurs par défaut.
# Conversion explicite avec NumPy/Pandas pour la capacité si nécessaire
df['capacity_mw'] = pd.to_numeric(df['capacity_mw'], errors='coerce')

# 2. Exploratory Data Analysis
print("\nStatistiques clés pour la capacité (MW) :")
stats_summary = df['capacity_mw'].agg(['mean', 'median', 'std'])
print(stats_summary)

