# Correction : Remplacement de 'primary_fuel' par 'fuel1'
fuel_stats = (
    df.groupby("fuel1")
      ["capacity_mw"]
      .agg(
          ["mean",
           "median",
           "std",
           "count"]
      )
)

print(fuel_stats)

# Correction : Utilisation du nom de colonne correct 'fuel1'
coal = df[
    df["fuel1"] == "Coal"
]["capacity_mw"]

gas = df[
    df["fuel1"] == "Gas"
]["capacity_mw"]

t_stat, p_value = stats.ttest_ind(
    coal,
    gas,
    equal_var=False
)

print(f"\nT-test statistics between Coal and Gas:")
print(f"T-stat: {t_stat}")
print(f"P-value: {p_value}")
alpha = 0.05

if p_value < alpha:
    print(
        "Reject H0"
    )
else:
    print(
        "Fail to reject H0"
    )

