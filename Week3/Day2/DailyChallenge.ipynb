numeric_cols = df.select_dtypes(
    include=np.number
).columns

for col in numeric_cols:
    df[col].fillna(
        df[col].median(),
        inplace=True
    )

categorical_cols = df.select_dtypes(
    include="object"
).columns

for col in categorical_cols:
    df[col].fillna(
        df[col].mode()[0],
        inplace=True
    )
  

df["capacity_mw"] = np.array(
    pd.to_numeric(
        df["capacity_mw"],
        errors="coerce"
    )
)
stats_summary = df.describe()

print(stats_summary)
for col in numeric_cols:

    print(f"\n{col}")

