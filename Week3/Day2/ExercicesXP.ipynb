import numpy as np

# Generate dates for 2023
dates = np.arange(
    np.datetime64('2023-01-01'),
    np.datetime64('2024-01-01')
)

# Slices
jan_mar = dates[:90]
apr_jun = dates[90:181]
jul_sep = dates[181:273]
oct_dec = dates[273:]

print("January to March:")
print(jan_mar)

print("\nApril to June:")
print(apr_jun)

print("\nJuly to September:")
print(jul_sep)

print("\nOctober to December:")
print(oct_dec)
import numpy as np
import pandas as pd

# NumPy Array
numpy_array = np.array([
    [1, 2],
    [3, 4],
    [5, 6]
])

# NumPy -> DataFrame
df = pd.DataFrame(
    numpy_array,
    columns=['Column1', 'Column2']
)

print("DataFrame:")
print(df)

# DataFrame -> NumPy
back_to_numpy = df.to_numpy()

print("\nConverted Back to NumPy:")
print(back_to_numpy)
import numpy as np
import matplotlib.pyplot as plt

# Create dataset
data = np.random.rand(20)

# Line graph
plt.figure(figsize=(10, 5))

plt.plot(
    data,
    marker='o'
)

plt.title("Random Numbers Line Graph")
plt.xlabel("Index")
plt.ylabel("Value")

plt.grid(True)

plt.show()
