import numpy as np

# Dataset
productivity_before = np.random.normal(
    loc=50,
    scale=10,
    size=30
)

productivity_after = productivity_before + np.random.normal(
    loc=5,
    scale=3,
    size=30
)

# Means
mean_before = np.mean(productivity_before)
mean_after = np.mean(productivity_after)

print("Mean Before Training:", mean_before)
print("Mean After Training:", mean_after)

# Difference
difference = mean_after - mean_before

print("Difference:", difference)

if difference > 0:
    print("Conclusion: Productivity improved after training.")
else:
    print("Conclusion: No evidence of improvement.")
