import numpy as np

# Create a 3x3 matrix
matrix = np.array([
    [2, 1, 3],
    [1, 0, 2],
    [4, 1, 8]
])

print("Matrix:")
print(matrix)

# Determinant
determinant = np.linalg.det(matrix)
print("\nDeterminant:")
print(determinant)

# Inverse
inverse_matrix = np.linalg.inv(matrix)
print("\nInverse Matrix:")
print(inverse_matrix)
import numpy as np

# Generate 50 random numbers
data = np.random.rand(50)

# Mean
mean_value = np.mean(data)

# Median
median_value = np.median(data)

# Standard deviation
std_value = np.std(data)

print("Mean:", mean_value)
print("Median:", median_value)
print("Standard Deviation:", std_value)
import numpy as np

# January 2023 dates
dates = np.arange(
    np.datetime64('2023-01-01'),
    np.datetime64('2023-02-01')
)

print("Original Dates:")
print(dates)

# Convert format YYYY/MM/DD
formatted_dates = [
    str(date).replace('-', '/')
    for date in dates
]

print("\nFormatted Dates:")
print(formatted_dates)
import numpy as np
import pandas as pd

# Create DataFrame
df = pd.DataFrame(
    np.random.randint(1, 100, size=(10, 3)),
    columns=['A', 'B', 'C']
)

print("DataFrame:")
print(df)

# Conditional selection
selected_data = df[df['A'] > 50]

print("\nRows where A > 50:")
print(selected_data)

# Aggregation functions
print("\nColumn Sums:")
print(df.sum())

print("\nColumn Means:")
print(df.mean())
