Hypothesis Testing

Comparaison entre deux années

Exemple :

* H0 : Les moyennes de clôture 2022 et 2023 sont identiques.
* H1 : Elles sont différentes.

close_2022 = df[df.index.year == 2022]['Close']
close_2023 = df[df.index.year == 2023]['Close']

t_stat, p_value = stats.ttest_ind(close_2022, close_2023, equal_var=False)

print("T-statistic :", t_stat)
print("P-value :", p_value)

if p_value < 0.05:
    print("Rejet de H0 : Les moyennes sont significativement différentes.")
else:
    print("Impossible de rejeter H0 : Pas de différence significative.")

# Visualisation des rendements
plt.figure(figsize=(10,5))
plt.hist(df['Daily_Return'].dropna(), bins=50)
plt.title("Distribution of Daily Returns")
plt.show()

# Tests de normalité
shapiro_test = stats.shapiro(df['Daily_Return'].dropna().sample(5000))
print("Shapiro-Wilk Test:", shapiro_test)

returns = df['Daily_Return'].dropna()
ks_test = stats.kstest(returns, 'norm', args=(returns.mean(), returns.std()))
print("Kolmogorov-Smirnov Test:", ks_test)

# Lissage du signal (Savgol filter)
df['Smoothed_Close'] = signal.savgol_filter(df['Close'], window_length=51, polyorder=3)
print("\nFiltre Savitzky-Golay appliqué à la colonne 'Smoothed_Close'.")
