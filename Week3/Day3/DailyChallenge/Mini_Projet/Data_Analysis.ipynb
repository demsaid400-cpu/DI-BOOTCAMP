stats_summary = []

for col in df.columns:
    if col != 'price_range':

        mode_val = stats.mode(df[col], keepdims=True)[0][0]

        stats_summary.append([
            col,
            df[col].mean(),
            df[col].median(),
            mode_val
        ])

summary_df = pd.DataFrame(
    stats_summary,
    columns=['Feature','Mean','Median','Mode']
)

summary_df
variability = []

for col in df.columns:
    if col != 'price_range':

        variability.append([
            col,
            np.ptp(df[col]),
            np.var(df[col]),
            np.std(df[col])
        ])

variability_df = pd.DataFrame(
    variability,
    columns=['Feature','Range','Variance','Std Dev']
)

variability_df
distribution_analysis = []

for col in df.columns:
    if col != 'price_range':

        distribution_analysis.append([
            col,
            skew(df[col]),
            kurtosis(df[col])
        ])

distribution_df = pd.DataFrame(
    distribution_analysis,
    columns=['Feature','Skewness','Kurtosis']
)

distribution_df

Interprétation

* Skewness > 0 : asymétrie à droite
* Skewness < 0 : asymétrie à gauche
* Kurtosis > 0 : présence d’extrêmes
* Kurtosis < 0 : distribution aplatie

correlations = {}

for col in df.columns:
    if col != 'price_range':

        corr, p_value = pearsonr(
            df[col],
            df['price_range']
        )

        correlations[col] = corr

corr_df = pd.DataFrame(
    correlations.items(),
    columns=['Feature','Correlation']
)

corr_df.sort_values(
    by='Correlation',
    ascending=False
)

