import pandas as pd
from scipy.stats import f_oneway
import matplotlib.pyplot as plt

# Liste des colonnes à tester suite à votre demande
cols_to_test = ['ram', 'int_memory', 'px_height', 'px_width']

for col in cols_to_test:
    # Création des groupes pour chaque catégorie de prix
    groups = [df[df['price_range'] == i][col] for i in range(4)]

    # Calcul de l'ANOVA
    f_stat, p_value = f_oneway(*groups)

    print(f"Analyse ANOVA pour {col} :")
    print(f"  F-statistic : {f_stat:.4f}")
    print(f"  P-value     : {p_value:.4e}")

    if p_value < 0.05:
        print("  Résultat    : Différence significative entre les catégories de prix.\n")
    else:
        print("  Résultat    : Pas de différence significative.\n")

